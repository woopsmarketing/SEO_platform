# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (Brevo)
BREVO_API_KEY=xkeysib-your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@seoworld.co.kr
BREVO_SENDER_NAME=SEO월드
ADMIN_NOTIFICATION_EMAIL=your-admin@email.com

# Monitoring
SENTRY_DSN=https://your-dsn@sentry.io/project-id
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# AI (On-page SEO Audit)
OPENAI_API_KEY=sk-your-openai-api-key

# External APIs
NAMECHEAP_API_KEY=your-namecheap-key
NAMECHEAP_API_USER=your-namecheap-user
RAPIDAPI_KEY=your-rapidapi-key

# Search Engine Verification
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_NAVER_VERIFICATION=

# 백링크샵 공용 캐시 API (3프로젝트 공유 — backlinkshop/도메인체커/SEO월드)
# 외부 API(RapidAPI/Serper/VebAPI) 호출 전에 이 캐시를 먼저 조회한다
CACHE_API_URL=https://backlinkshop.co.kr
CACHE_API_KEY=your-shared-cache-key
